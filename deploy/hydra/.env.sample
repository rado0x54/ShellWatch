# Environment for docker-compose.hydra.yml — copy to .env.hydra and edit.
# Use with:  docker compose --env-file .env.hydra -f docker-compose.hydra.yml up -d
#
# These values are DEV ONLY. For any shared/prod deployment, generate fresh
# secrets (openssl rand -hex 16) and keep the admin port (:4445) off the
# public internet.

HYDRA_PG_USER=hydra
HYDRA_PG_PASSWORD=hydra-dev-secret
HYDRA_PG_DB=hydra

# Hydra's system secret — used to encrypt data at rest in Postgres. Must be at
# least 16 characters. Rotating it invalidates all existing tokens/sessions.
HYDRA_SECRETS_SYSTEM=this-is-a-dev-only-system-secret-change-me
