# Environment for docker-compose.hydra.yml — copy to .env.hydra and edit.
# Use with:  docker compose --env-file .env.hydra -f docker-compose.hydra.yml up -d
#
# These values are DEV ONLY. For any shared/prod deployment, generate a fresh
# secret (openssl rand -hex 16) and keep the admin port (:4445) off the public
# internet.

# Hydra's datastore. Defaults to a file SQLite in ./data (the same folder
# ShellWatch keeps its own DB). Uncomment to override — e.g. point elsewhere, or
# use Postgres/MySQL if you outgrow SQLite.
# HYDRA_DSN=sqlite:///data/hydra.sqlite?_fk=true

# Hydra's system secret — encrypts data at rest. Must be at least 16 characters.
# Rotating it invalidates all existing tokens/sessions.
HYDRA_SECRETS_SYSTEM=this-is-a-dev-only-system-secret-change-me
