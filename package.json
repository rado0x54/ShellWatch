{
  "name": "shellwatch",
  "version": "0.0.0",
  "description": "SSH session broker with browser UI and MCP interface",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch src/index.ts 2>&1 | tee logs/dev.log\" \"cd client && npx vite dev\"",
    "dev:server": "tsx watch src/index.ts 2>&1 | tee logs/dev.log",
    "build": "tsc && pnpm build:client",
    "build:server": "tsc",
    "build:client": "cd client && npx svelte-kit sync && npx vite build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "check:svelte": "cd client && npx svelte-kit sync && npx svelte-check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "cd client && npx svelte-kit sync",
    "test": "vitest run --exclude 'src/test/integration/**'",
    "test:integration": "vitest run src/test/integration",
    "test:golden": "vitest run src/test/integration/golden-*.test.ts",
    "test:golden:update": "UPDATE_GOLDENS=1 vitest run src/test/integration/golden-*.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "hydra:migrate": "docker compose --profile hydra run --rm hydra migrate sql -e --yes",
    "update:aaguids": "tsx scripts/update-aaguids.ts",
    "licenses:bundle": "node scripts/bundle-licenses.mjs",
    "spdx:check": "node scripts/spdx-headers.mjs",
    "spdx:write": "node scripts/spdx-headers.mjs --write",
    "api:preview": "npx --yes @redocly/cli@latest build-docs docs/api/openapi.yaml -o docs/api/openapi.html && open docs/api/openapi.html",
    "api:lint": "npx --yes @redocly/cli@latest lint docs/api/openapi.yaml",
    "api:codegen-check": "bash scripts/check-api-codegen.sh",
    "sync:fonts": "node scripts/sync-fonts.mjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [],
  "author": "Martin Riedel",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fastify/middie": "^9.3.2",
    "@fontsource-variable/geist": "5.2.8",
    "@fontsource-variable/geist-mono": "5.2.7",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/ssh2": "^1.15.5",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "cbor-x": "^1.6.4",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "ssh2": "github:rado0x54/ssh2#shellwatch",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,svelte}": "eslint",
    "*.{ts,svelte,js,json,css,md,yaml,yml}": "prettier --write"
  }
}
