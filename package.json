    "@simplewebauthn/server": "^13.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "cbor-x": "^1.6.4",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "ssh2": "github:rado0x54/ssh2#debug/signature-dump",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
